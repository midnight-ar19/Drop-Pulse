<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DropPulse</title>

    <!-- TailwindCSS -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/jquery.dataTables.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.tailwindcss.min.css" />

    <!-- Fuente elegante -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #2563eb; /* Azul elegante */
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f9fafb;
            color: #1f2937;
        }

        /* Navbar elegante */
        .navbar {
            backdrop-filter: blur(12px);
            background: rgba(255, 255, 255, 0.8);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        }

        .nav-link {
            transition: color 0.3s, transform 0.3s;
        }

            .nav-link:hover {
                color: var(--primary);
                transform: translateY(-1px);
            }

        /* Contenedor principal */
        main {
            background: white;
            border-radius: 1rem;
            padding: 2rem;
            margin-top: 2rem;
            margin-bottom: 3rem;
            box-shadow: 0 4px 24px rgba(0, 0, 0, 0.05);
            transition: all 0.3s ease;
        }

        /* Footer */
        footer {
            background: #111827;
            color: #d1d5db;
            padding: 1.5rem 0;
            text-align: center;
            font-size: 0.9rem;
        }

            footer a {
                color: #60a5fa;
                transition: color 0.2s;
            }

                footer a:hover {
                    color: #93c5fd;
                }

        /* Botones DataTables */
        .dataTables_wrapper .dataTables_paginate .paginate_button {
            border-radius: 0.375rem;
            transition: all 0.2s;
        }

            .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
                background-color: #2563eb !important;
                color: white !important;
            }

        /* Animación de aparición */
        .fade-in {
            opacity: 0;
            transform: translateY(15px);
            animation: fadeIn 0.6s ease forwards;
        }
        @@keyframes fadeIn {
            to

        {
            opacity: 1;
            transform: translateY(0);
        }

        }
    </style>
</head>
<body class="min-h-screen flex flex-col">

    <!-- Navbar -->
    <header class="navbar fixed top-0 left-0 w-full z-50">
        <nav class="container mx-auto flex items-center justify-between py-4 px-6">
            <a asp-area="" asp-controller="Home" asp-action="Index" class="text-xl font-semibold text-gray-800 hover:text-blue-600 transition">DropPulse 💧</a>
            <ul class="flex items-center space-x-6 text-gray-700">
                <li><a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a></li>
                <li><a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacidad</a></li>
            </ul>
        </nav>
    </header>

    <!-- Contenido -->
    <main role="main" class="container mx-auto mt-24 fade-in">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="mt-auto">
        <div class="container mx-auto">
            &copy; 2025 <span class="font-semibold text-white">DropPulse</span> —
            <a asp-controller="Home" asp-action="Privacy">Política de Privacidad</a>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
