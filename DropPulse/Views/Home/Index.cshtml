@model List<HistorialViewModel>

<div class="container mx-auto py-10 px-4 fade-in">

    <!-- Encabezado -->
    <div class="mb-8 text-center">
        <h1 class="text-3xl font-semibold text-gray-800 mb-2">
            Panel de Historial de Riego y Sensores 💧
        </h1>
        <p class="text-gray-500 max-w-2xl mx-auto">
            Visualización de registros de humedad, temperatura y riego del sistema.
        </p>
    </div>

    <!-- Acción -->
    <div class="flex flex-col items-center gap-4 mb-6">
        <p class="text-gray-600">Haz clic en el botón para iniciar una nueva verificación del sistema de riego.</p>

        <a asp-controller="Home" asp-action="TriggerIrrigationCheck"
           class="inline-flex items-center gap-2 bg-blue-600 text-white font-medium px-5 py-2.5 rounded-lg shadow-md hover:bg-blue-700 transition duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24"
                 stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
            Iniciar Verificación de Riego
        </a>
    </div>

    <!-- Mensaje -->
    @if (TempData["Message"] != null)
    {
        <div class="bg-green-100 border border-green-300 text-green-700 px-4 py-3 rounded-lg mb-6 shadow-sm">
            @TempData["Message"]
        </div>
    }

    <!-- Tarjeta -->
    <div class="bg-white shadow-xl rounded-2xl overflow-hidden border border-gray-100">
        <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
            <h5 class="text-lg font-semibold text-gray-700">Registros Recientes</h5>
        </div>

        <div class="p-4">
            <div class="overflow-x-auto">
                <table id="historialTable" class="min-w-full border-collapse text-sm">
                    <thead>
                        <tr class="bg-gray-100 text-gray-700 uppercase text-xs tracking-wider">
                            <th class="text-center py-3 px-4">ID</th>
                            <th class="py-3 px-4">Humedad del Suelo</th>
                            <th class="py-3 px-4">Humedad del Aire</th>
                            <th class="py-3 px-4">Temperatura</th>
                            <th class="text-center py-3 px-4">Estado de Riego</th>
                        </tr>
                    </thead>

                    <tbody class="text-gray-700">
                        @foreach (var registro in Model)
                        {
                            <tr class="hover:bg-gray-50 transition">
                                <td class="text-center font-semibold text-gray-500 py-3 px-4">@registro.ID</td>
                                <td class="py-3 px-4">@registro.HumedadSuelo.ToString("F2") %</td>
                                <td class="py-3 px-4">@registro.HumedadAire.ToString("F2") %</td>
                                <td class="py-3 px-4">@registro.Temperatura.ToString("F2") °C</td>
                                <td class="text-center py-3 px-4">
                                    @if (registro.Regado == "Sí")
                                    {
                                        <span class="inline-block bg-green-100 text-green-700 text-xs font-semibold px-3 py-1 rounded-full">
                                            REGADO
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-block bg-red-100 text-red-700 text-xs font-semibold px-3 py-1 rounded-full">
                                            NO REGADO
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="bg-gray-50 border-t border-gray-200 px-6 py-3 text-xs text-gray-500 text-right">
            Último renderizado: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#historialTable').DataTable({
                language: { url: '//cdn.datatables.net/plug-ins/1.13.4/i18n/es-ES.json' },
                pageLength: 10,
                lengthMenu: [5, 10, 25, 50],
                order: [[0, 'desc']]
            });
        });
    </script>
}
