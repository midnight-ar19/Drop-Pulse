@model List<HistorialViewModel>

<div class="container py-5">

    <h1 class="mb-4 fw-light text-dark border-bottom pb-2">
        Panel de Historial de Riego y Sensores 💧
    </h1>
    <p class="lead text-muted">
        Visualización de registros de humedad, temperatura y riego del sistema.
    </p>

    <p>Haz clic en el botón para iniciar una nueva verificación del sistema de riego.</p>

    <a asp-controller="Home" asp-action="TriggerIrrigationCheck" class="btn btn-primary">
        Iniciar Verificación de Riego
    </a>

    <hr />

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success">
            @TempData["Message"]
        </div>
    }

    <div class="card shadow-lg border-0 mt-4">
        <div class="card-header bg-white border-bottom py-3">
            <h5 class="mb-0 text-dark">Registros Recientes</h5>
        </div>

        <div class="card-body p-3">
            <div class="table-responsive">
                <table id="historialTable" class="table table-striped table-bordered align-middle">
                    <thead class="table-light text-uppercase small">
                        <tr>
                            <th class="text-center">ID</th>
                            <th>Humedad del Suelo</th>
                            <th>Humedad del Aire</th>
                            <th>Temperatura</th>
                            <th class="text-center">Estado de Riego</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var registro in Model)
                        {
                            <tr>
                                <td class="text-center fw-bold text-secondary">@registro.ID</td>
                                <td><i class="bi bi-moisture"></i> @registro.HumedadSuelo.ToString("F2") %</td>
                                <td><i class="bi bi-droplet-half"></i> @registro.HumedadAire.ToString("F2") %</td>
                                <td><i class="bi bi-thermometer-sun"></i> @registro.Temperatura.ToString("F2") °C</td>
                                <td class="text-center">
                                    @if (registro.Regado == "Sí")
                                    {
                                        <span class="badge rounded-pill bg-success-subtle text-success py-2 px-3">REGADO</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-danger-subtle text-danger py-2 px-3">NO REGADO</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer bg-light border-top small text-muted text-end">
            Último renderizado: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#historialTable').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.4/i18n/es-ES.json'
                },
                pageLength: 10,
                lengthMenu: [5, 10, 25, 50],
                order: [[0, 'desc']]
            });
        });
    </script>
}
